        "query": "SELECT distinct\n  v.id,\n  v.email,\n  v.moodle_id,\n  v.zendesk_user_id, \n  v.condition, \n  m.volunteer_zendesk_ticket_id ticket_match, \n  m.msr_zendesk_ticket_id ticket_pedido_acolhimento, \n  v.first_name        AS volunteer_first_name,\n  p.first_name        AS msr_first_name, \n  m.match_id\n  from match.matches m\n  inner join  volunteers v on m.volunteer_id = v.id \n  INNER JOIN pii_sec.msr_pii p  ON p.msr_id = m.msr_id\n  where v.moodle_id = {{ $json.user_id }} \n  and m.status = 'in_contact'\nlimit 1\n",
