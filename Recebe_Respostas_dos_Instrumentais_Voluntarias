service_referral_reason'),\n    public_services_articulated: getArrayAnswer(item,'public_services_articulated')\n  }\n\n  const acompanhamento_psicologico = {\n    psychologist_contact: getUniqueAnswer(item, 'psychologist_contact'),\n    psychologist_collaboration: getUniqueAnswer(item, 'psychologist_collaboration'),\n    psychologist_collaboration_learnings: getTextAnswer(item,'psychologist_collaboration_learnings')\n  }\n\n  const volunteer_experience = {\n    gender_procedural_abuse: getUniqueAnswer(item, 'gender_procedural_abuse'),\n    gender_procedural_abuse_report: getUniqueAnswer(item, 'gender_procedural_abuse_report'),\n    team_response_to_report: getTextAnswer(item, 'team_response_to_report'),\n    lessons_learned: getTextAnswer(item,'lessons_learned'),\n    volunteer_feelings: getTextAnswer(item,'volunteer_feelings')\n  }\n\n  const suporte_mapa = {\n    requested_technical_support: getUniqueAnswer(item, 'requested_technical_support'),\n    technical_support_help: getArrayAnswer(item, 'technical_support_help'),\n    felt_supported: getUniqueAnswer(item, 'felt_supported'),\n    message_to_team: getTextAnswer(item,'message_to_team')\n  }\n\n  const suggestions = getTextAnswer(item, 'suggestions')\n\n  answers = {\n    contrato_atendimento,\n    sobre_violencia,\n    acompanhamento_psicologico,\n    encaminhamento,\n    acompanhamento_juridico,\n    volunteer_experience,\n    suporte_mapa,\n    suggestions,\n    matchId,\n    volunteerFirstName,\n    msrFirstName\n  }\n}\n\nreturn answers;"
