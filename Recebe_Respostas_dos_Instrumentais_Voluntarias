      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst disabilityType = {\n  \"Deficiência Física: Limitações motoras que afetam a mobilidade.\": \"physical\",\n  \"Deficiência Visual: Cegueira ou baixa visão.Deficiência Auditiva: Surdez ou perda auditiva.\": \"visual\",\n  \"Deficiência Auditiva: Surdez ou perda auditiva.\": \"hearing\",\n  \"Deficiência Intelectual: Dificuldades cognitivas que afetam a aprendizagem e o raciocínio.\": \"intellectual\",\n  \"Deficiência Psíquica: Transtornos mentais que afetam o comportamento e o funcionamento cotidiano.\": \"psychic\",\n  \"Deficiência Múltipla: Combinação de duas ou mais deficiências.\": \"multiple\",\n  \"Não é PcD\": \"not_pcd\"\n}\n\nconst contractFormat = {\n  \"Remoto\": \"remote\",\n  \"Presencial\": \"in_person\",\n  \"Híbrido (remoto e presencial)\": \"hybrid\"\n}\n\nconst violenceAwareness = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não tenho insumo suficiente ainda para responder essa pergunta.\":\"insufficient_input\"\n}\n\nconst safetyPlanUsed  = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não se aplica\": \"not_applicable\"\n}\n\nconst lawyerContact = {\n  \"Sim, estou em contato\": \"in_contact\",\n  \"Não, não estou em contato\": \"not_in_contact\",\n  \"A acolhida não está em acompanhamento jurídico intermediado pelo Mapa do Acolhimento\": \"not_receiving_support\",\n  \"Não tenho essa informação\": \"unknown\"\n}\n\nconst lawyerCollaboration = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não se aplica\": \"not_applicable\"}\n\nconst  supportSatisfaction = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não se aplica\": \"not_applicable\"}\n\nfor (const item of $input.all()) {\n  item.json.dados_acolhida.disability_type = disabilityType[item.json.dados_acolhida.disability_type];\n  item.json.contrato_atendimento.contract_format = contractFormat[item.json.contrato_atendimento.contract_format];\n  item.json.sobre_violencia.violence_awareness = violenceAwareness[item.json.sobre_violencia.violence_awareness];\n  item.json.acompanhamento_psicologico.safety_plan_used = safetyPlanUsed[ item.json.acompanhamento_psicologico.safety_plan_used ]; \n  item.json.acompanhamento_juridico.lawyer_contact = lawyerContact[ item.json.acompanhamento_juridico.lawyer_contact];\n  item.json.acompanhamento_juridico.lawyer_collaboration = lawyerCollaboration[item.json.acompanhamento_juridico.lawyer_collaboration ]?lawyerCollaboration[item.json.acompanhamento_juridico.lawyer_collaboration ]:\"not_applicable\"\nitem.json.suporte_mapa.support_satisfaction = supportSatisfaction[item.json.suporte_mapa.support_satisfaction]\n  \n}\n\nreturn $input.all();"
      },
