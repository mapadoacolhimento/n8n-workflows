_awareness];\n  item.json.acompanhamento_juridico.safety_plan_used = safetyPlanUsed[ item.json.acompanhamento_juridico.safety_plan_used ]; \n  \n  item.json.encaminhamento.cpublic_service_referral = publicServiceReferralType[item.json.encaminhamento.cpublic_service_referral]\n  item.json.acompanhamento_psicologico.psychologist_contact = psychologistContact[ item.json.acompanhamento_psicologico.psychologist_contact];\n  item.json.acompanhamento_psicologico.psychologist_collaboration = psychologistCollaboration[item.json.acompanhamento_psicologico.psychologist_collaboration ]?psychologistCollaboration[item.json.acompanhamento_psicologico.psychologist_collaboration ]:\"not_applicable\"\n  item.json.suporte_mapa.support_satisfaction = item.json.suporte_mapa.support_satisfaction? supportSatisfaction[item.json.suporte_mapa.support_satisfaction]: 'not_applicable'\n\n  item.json.acompanhamento_juridico.pro_bono_in_case_files = proBonoInCaseFiles[ item.json.acompanhamento_juridico.pro_bono_in_case_files]\n\n  item.json.acompanhamento_juridico.main_demand_subcategory = mainDemandCategory[item.json.acompanhamento_juridico.main_demand_category]? item.json.acompanhamento_juridico.main_demand_subcategory: item.json.acompanhamento_juridico.main_demand_category;\n  item.json.acompanhamento_juridico.main_demand_category = mainDemandCategory[item.json.acompanhamento_juridico.main_demand_category]? mainDemandCategory[item.json.acompanhamento_juridico.main_demand_category]: \"other\";\n \n  \n  \n}\n\nreturn $input.all();"
