        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\n\nfunction getHiddenFieldValue(item, fieldLabel){\n  return item.json.body.data.fields.find(\n    (element) => element.label === fieldLabel\n  ).value;\n}\n\nfunction getUniqueAnswer(item, fieldLabel){\n  const field = item.json.body.data.fields.find(\n    (element) => element.type === 'MULTIPLE_CHOICE' && element.label === fieldLabel\n  );\n  \n  if(!field.value) return null\n  \n  const answer = field.options.find(\n    (element) => element.id == field.value\n  ).text;\n\n  return answer\n}\n\nfunction getArrayAnswer(item, fieldLabel){\n  const field = item.json.body.data.fields.find(\n    (element) => element.type === 'MULTIPLE_CHOICE' && element.label === fieldLabel\n  );\n\n  const valuesArray = field.value\n\n  if(!valuesArray) return null\n\n  const answersArray = valuesArray.map((value) => {\n    const answer = field.options.find(\n      (element) => element.id == value\n    ).text;\n\n    return answer\n    \n  })\n\n  return answersArray\n}\n\nfunction getTextAnswer(item, fieldLabel){\n  const field = item.json.body.data.fields.find(\n    (element) => element.type === 'TEXTAREA' && element.label === fieldLabel\n  );\n\n  if(!field.value) return null\n  \n  const answer = field.value;\n\n  return answer\n}\n\nfunction getInputAnswer(item, fieldLabel){\n    const value =  item.json.body.data.fields.find(objeto => objeto.label == fieldLabel).value\n  if(!value) return null\n  return value\n}\n\nconst changeDateFormatTo = dateStr => {\n    const [year, month, day] = dateStr.split('-');\n    return `${day}/${month}/${year}`;\n};\nlet answers = {}\nfor (const item of $input.all()) {\n  \n  const matchId = getHiddenFieldValue(item, \"match_id\")\n  const msrFirstName = getHiddenFieldValue(item, \"msr_first_name\")\n  const volunteerFirstName = getHiddenFieldValue(item, \"volunteer_first_name\")\n\n  const dados_acolhida = {\n    disability_type: getArrayAnswer(item, 'disability_type')\n  }\n  const contrato_atendimento = {\n    support_start_date: getInputAnswer(item, 'support_start_date'),\n    support_start_date_str:  changeDateFormatTo(getInputAnswer(item, 'support_start_date')),\n    has_pro_bono_contract: getUniqueAnswer(item, 'has_pro_bono_contract'),\n    has_absence_policy: getUniqueAnswer(item, 'has_absence_policy'),\n    contract_format: getUniqueAnswer(item, 'contract_format'),\n    safe_contact_methods: getArrayAnswer(item,'safe_contact_methods')\n  } \n\n  const sobre_violencia = {\n    violence_awareness:getUniqueAnswer(item, 'violence_awareness'),\n    violence_types: getArrayAnswer(item, 'violence_types'),\n    behavioral_impacts: getArrayAnswer(item, 'behavioral_impacts'),\n    relationship_impacts: getArrayAnswer(item, 'relationship_impacts'),\n    socioeconomic_impacts: getArrayAnswer(item, 'socioeconomic_impacts'),\n    security_impacts: getArrayAnswer(item, 'security_impacts'),\n    violence_assessment: getTextAnswer(item, 'violence_assessment'),\n  }\n\n  const acompanhamento_psicologico = {\n    main_demand: getArrayAnswer(item, 'main_demand'),\n    case_conduction_details: getTextAnswer(item, 'case_conduction_details'),\n    safety_plan_used: getUniqueAnswer(item, 'safety_plan_used'),\n    safety_plan_description: getTextAnswer(item, 'safety_plan_description'),\n    clinical_difficulties_exist: getUniqueAnswer(item, 'clinical_difficulties_exist'),\n    clinical_difficulties: getTextAnswer(item, 'clinical_difficulties'),\n    bonding_strategies: getTextAnswer(item,'bonding_strategies')\n  } \n\n  const encaminhamento = {\n    case_referrals: getArrayAnswer(item, 'case_referrals'),\n    public_service_referral_reason: getUniqueAnswer(item, 'public_service_referral_reason'),\n    public_services_articulated: getArrayAnswer(item,'public_services_articulated')\n  }\n\n  const acompanhamento_juridico = {\n    lawyer_contact: getUniqueAnswer(item, 'lawyer_contact'),\n    lawyer_collaboration: getUniqueAnswer(item, 'lawyer_collaboration')\n  }\n\n  const situacoes_criticas = {\n    suicide_risk_concern: getUniqueAnswer(item, 'suicide_risk_concern'),\n    has_psychiatric_support: getUniqueAnswer(item, 'has_psychiatric_support')\n  }\n\n  const volunteer_experience = {\n    volunteer_feelings: getTextAnswer(item,'volunteer_feelings')\n  }\n\n  const suporte_mapa = {\n    need_technical_support_last_45D: getUniqueAnswer(item, 'need_technical_support_last_45D'),\n    technical_support_help: getArrayAnswer(item, 'technical_support_help'),\n    still_need_help: getTextAnswer(item, 'still_need_help'),\n    support_satisfaction: getUniqueAnswer(item, 'support_satisfaction')\n  }\n\n  const suggestions = getTextAnswer(item, 'suggestions')\n\n  answers = {\n    dados_acolhida,\n    contrato_atendimento,\n    sobre_violencia,\n    acompanhamento_psicologico,\n    encaminhamento,\n    acompanhamento_juridico,\n    situacoes_criticas,\n    volunteer_experience,\n    suporte_mapa,\n    suggestions,\n    matchId,\n    volunteerFirstName,\n    msrFirstName\n  }\n}\n\nreturn answers;"
