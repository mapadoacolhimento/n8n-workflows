        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nconst disabilityType = {\n  \"Deficiência Física: Limitações motoras que afetam a mobilidade.\": \"physical\",\n  \"Deficiência Visual: Cegueira ou baixa visão.Deficiência Auditiva: Surdez ou perda auditiva.\": \"visual\",\n  \"Deficiência Auditiva: Surdez ou perda auditiva.\": \"hearing\",\n  \"Deficiência Intelectual: Dificuldades cognitivas que afetam a aprendizagem e o raciocínio.\": \"intellectual\",\n  \"Deficiência Psíquica: Transtornos mentais que afetam o comportamento e o funcionamento cotidiano.\": \"psychic\",\n  \"Deficiência Múltipla: Combinação de duas ou mais deficiências.\": \"multiple\",\n  \"Não é PcD\": \"not_pcd\"\n}\n\nconst contractFormat = {\n  \"Remoto\": \"remote\",\n  \"Presencial\": \"in_person\",\n  \"Híbrido (remoto e presencial)\": \"hybrid\"\n}\n\nconst violenceAwareness = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não tenho insumo suficiente ainda para responder essa pergunta.\":\"insufficient_input\"\n}\n\nconst safetyPlanUsed  = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não se aplica\": \"not_applicable\"\n}\n\nconst publicServiceReferralReason = {\n  \"Encaminhei devido a risco à integridade física/psicológica ou violência em curso, necessitando proteção da rede pública.\" : \"physical_psychological_risk\",\n  \"Encaminhei por demanda de saúde mental que necessita acompanhamento especializado e contínuo pela rede pública.\":\"mental_health_demand\",\n  \"Encaminhei devido à vulnerabilidade social e necessidade de acesso a direitos e serviços socioassistenciais.\":\"social_vulnerability\",\n  \"Encaminhei porque o caso exige orientações e medidas que ultrapassam o escopo do Mapa do Acolhimento\":\"exceeds_scope\",\n  \"Não identifiquei necessidade de encaminhamento para serviços públicos neste momento.\":\"no_need_identified\"\n  }\n\nconst psychologistContact = {\n  \"Sim, estou em contato\": \"in_contact\",\n  \"Não, não estou em contato\": \"not_in_contact\",\n  \"A acolhida não está em acompanhamento jurídico intermediado pelo Mapa do Acolhimento\": \"not_receiving_support\"\n}\n\nconst psychologistCollaboration  = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não se aplica\": \"not_applicable\"}\n\nconst weeklyHours = {\n  \"1h\": \"one_hour\",\n  \"2h\": \"two_hours\",\n  \"3h a 5h\": \"three_to_five_hours\",\n  \"Mais de 5 horas\": \"more_than_five_hours\",\n}\n  \nconst mainDemandCategory = {\n  \"Atuação em temáticas de Direito de Família\": \"family_law\",\n  \"Atuação em temáticas de Direito Penal / Violência DomésticaSobre o acompanhamento psicológico\": \"criminal_law\",\n  \"Atuação em temáticas de Direito do Trabalho\": \"labor_law\",\n  \"Atuação relacionada a Direitos Patrimoniais\": \"property_rights\",\n  \"Informações e orientações sobre o sistema de justiça\": \"justice_system_info\",\n}\n\nconst proBonoInCaseFiles = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não se aplica\": \"not_applicable\"\n}\n\nconst publicServiceReferralType = {\n  \"Encaminhamento para serviço público e interrupção do atendimento pelo Mapa do Acolhimento\": \"referral_with_interruption\",\n  \"Articulação com o serviço público e continuidade de atendimento pelo Mapa do Acolhimento\":\"articulation_with_continuity\",\n  \"Não se aplica\": \"not_applicable\"\n\n}\n\nconst  supportSatisfaction = {\n  \"Sim\":\"yes\",\n  \"Não\":\"no\",\n  \"Não se aplica\": \"not_applicable\"}\n\nfor (const item of $input.all()) {\n  item.json.dados_acolhida.disability_type = disabilityType[item.json.dados_acolhida.disability_type];\n  item.json.contrato_atendimento.contract_format = contractFormat[item.json.contrato_atendimento.contract_format];\n  item.json.contrato_atendimento.weekly_hours = weeklyHours[item.json.contrato_atendimento.weekly_hours];\n  item.json.sobre_violencia.violence_awareness = violenceAwareness[item.json.sobre_violencia.violence_awareness];\n  item.json.acompanhamento_juridico.safety_plan_used = safetyPlanUsed[ item.json.acompanhamento_juridico.safety_plan_used ]; \n  item.json.encaminhamento.public_service_referral_reason = publicServiceReferralReason[item.json.encaminhamento.public_service_referral_reason]\n  item.json.encaminhamento.cpublic_service_referral = publicServiceReferralType[item.json.encaminhamento.cpublic_service_referral]\n  item.json.acompanhamento_psicologico.psychologist_contact = psychologistContact[ item.json.acompanhamento_psicologico.psychologist_contact];\n  item.json.acompanhamento_psicologico.psychologist_collaboration = psychologistCollaboration[item.json.acompanhamento_psicologico.psychologist_collaboration ]?psychologistCollaboration[item.json.acompanhamento_psicologico.psychologist_collaboration ]:\"not_applicable\"\n  item.json.suporte_mapa.support_satisfaction = supportSatisfaction[item.json.suporte_mapa.support_satisfaction]\n\n  item.json.acompanhamento_juridico.pro_bono_in_case_files = proBonoInCaseFiles[ item.json.acompanhamento_juridico.pro_bono_in_case_files]\n\n  item.json.acompanhamento_juridico.main_demand_subcategory = mainDemandCategory[item.json.acompanhamento_juridico.main_demand_category]? item.json.acompanhamento_juridico.main_demand_subcategory: item.json.acompanhamento_juridico.main_demand_category;\n  item.json.acompanhamento_juridico.main_demand_category = mainDemandCategory[item.json.acompanhamento_juridico.main_demand_category]? mainDemandCategory[item.json.acompanhamento_juridico.main_demand_category]: \"other\";\n \n  \n  \n}\n\nreturn $input.all();"
