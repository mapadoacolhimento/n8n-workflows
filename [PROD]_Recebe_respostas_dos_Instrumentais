aluation = getTextAnswer(item, \"written_evaluation\")\n  const agreements_fulfilled = getUniqueAnswer(item, \"agreements_fulfilled\")\n const is_receiving_service = getUniqueAnswer(item, \"is_receiving_service\")\n\n  output.push(\n    {\n      match_id: matchId,\n      msr_first_name: msrFirstName,\n      volunteer_first_name: volunteerFirstName,\n      had_to_pay_for_support: hadToPayForSupport,\n      has_received_clear_information: hasReceivedClearInformation,\n      handle_stress_anxiety: handleStressAnxiety,\n      case_progress: caseProgress,\n      satisfaction_level: satisfactionLevel,\n      expectations_met: expectationsMet,\n      written_evaluation: writtenEvaluation,\n      agreements_fulfilled: agreements_fulfilled,\n      is_receiving_service: is_receiving_service\n    }\n  )\n}\n\nreturn output;"
