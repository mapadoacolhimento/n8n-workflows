rFirstName = getHiddenFieldValue(item, \"volunteer_first_name\")\n\n  const encaminhamento = {\n    has_different_demand_info: getUniqueAnswer(item, 'has_different_demand_info'),\n    different_demand_description: getTextAnswer(item,'different_demand_description'),\n    interruption_reason: getArrayAnswer(item, 'interruption_reason'),\n    redirect_area_needed: getUniqueAnswer(item, 'redirect_area_needed'),\n    public_services_referral: getArrayAnswer(item,'public_services_referral')\n  }\n\n  const disponibilidade  = {\n    stay_in_project: getUniqueAnswer(item, 'stay_in_project'),\n    exit_or_suspend: getUniqueAnswer(item, 'exit_or_suspend'),\n    suspension_category: getUniqueAnswer(item, 'suspension_category'),\n    suspension_reason: getUniqueAnswer(item, 'suspension_reason'),\n    exit_reason: getTextAnswer(item, 'exit_reason')\n  }\n\n  answers = {\n    encaminhamento,\n    disponibilidade,\n    matchId,\n    volunteerFirstName,\n    msrFirstName\n  }\n}\n\nreturn answers;"
